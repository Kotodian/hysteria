#!/bin/sh
set -e

case "$1" in
    purge)
        if getent passwd hysteria >/dev/null; then
            userdel hysteria >/dev/null 2>&1 || true
        fi
        if getent group hysteria >/dev/null; then
            groupdel hysteria >/dev/null 2>&1 || true
        fi
        rm -rf /var/lib/hysteria
        rm -f /etc/hysteria/config.yaml.example
        rmdir /etc/hysteria 2>/dev/null || true
        rm -f /etc/sysctl.d/99-hysteria.conf
        ;;
    remove|upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        if [ -d /run/systemd/system ]; then
            systemctl daemon-reload || true
        fi
        ;;
esac

exit 0
