#!/bin/sh
set -e

case "$1" in
    configure)
        if ! getent group hysteria >/dev/null; then
            groupadd --system hysteria
        fi
        if ! getent passwd hysteria >/dev/null; then
            useradd --system --gid hysteria \
                --home-dir /var/lib/hysteria --no-create-home \
                --shell /usr/sbin/nologin \
                --comment "Hysteria service account" hysteria
        fi

        mkdir -p /var/lib/hysteria
        chown hysteria:hysteria /var/lib/hysteria
        chmod 0750 /var/lib/hysteria

        if [ -d /run/systemd/system ]; then
            systemctl daemon-reload || true
        fi

        if [ -x /sbin/sysctl ] || command -v sysctl >/dev/null 2>&1; then
            sysctl --system >/dev/null 2>&1 || true
        fi
        ;;
esac

exit 0
